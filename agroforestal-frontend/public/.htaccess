Options -MultiViews
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.html [QSA,L]

# index.html: nunca cachear (así siempre carga la versión más reciente)
<Files "index.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</Files>

# Assets con hash (JS/CSS): caché 1 año (son inmutables por el hash en el nombre)
<FilesMatch "\.(js|css|woff2|woff|ttf)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Imágenes y fuentes: caché 30 días
<FilesMatch "\.(png|jpg|jpeg|gif|svg|ico|webp)$">
  Header set Cache-Control "public, max-age=2592000"
</FilesMatch>
